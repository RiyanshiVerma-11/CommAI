# CommAI - Environment Configuration Template
# Copy this file to '.env' in the backend directory and update the settings.

# Secret key for JWT auth (auto-generated default works locally)
# SECRET_KEY=72210fafca4045a19f2a95b15deb9108comm-ai-secret-key-super-secure

# Database Connection (SQLite by default)
# DATABASE_URL=sqlite:///./comm_platform.db

# --- SMTP Email Configuration (Gmail App Passwords) ---
# 1. Enable 2-Step Verification on your Gmail account.
# 2. Go to Google Account -> Security -> App Passwords.
# 3. Generate a new app password for "Mail" (16 characters, no spaces).
SMTP_EMAIL=
SMTP_APP_PASSWORD=

# --- CallMeBot WhatsApp Configuration ---
# Optional: Set a default key if sending to a single test phone number.
# Recipients can get their keys by messaging CallMeBot (+34 644 71 81 84) on WhatsApp.
CALLMEBOT_DEFAULT_APIKEY=

# --- Default Country Code ---
# Pre-prepended to 10-digit phone numbers missing a country code prefix.
DEFAULT_COUNTRY_CODE=91

# --- Groq Translation Configuration ---
# Generate a free API key at https://console.groq.com/
GROQ_API_KEY=
